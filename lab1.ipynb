import numpy as np
import matplotlib.pyplot as plt


x_mu = np.array([6, 2, 4, 3, 4, 5, 0, 0, 0, 0])
N = len(x_mu)

X = x_mu.reshape(-1, 1)


n = np.arange(N).reshape(-1, 1)  # Wektory kolumnowy indeksów czasu 0..N-1
k = np.arange(N).reshape(1, -1)  # Wektor wierszowy indeksów częstotliwości 0..N-1


K = n @ k

W = np.exp(-1j * 2 * np.pi * K / N)



W_H = np.conjugate(W)  # Macierz odwrotna (bez skalowania 1/N)
x_synthesized = (1 / N) * (W_H @ X)


x_final = x_synthesized.flatten()


print(f"DANE: Wariant 1, N={N}")
print(f"Wektor wejściowy X: {x_mu}")
print("-" * 40)

print("\nMacierz K (pierwsze 5x5 elementów):")
print(K[:5, :5])

print("\nMacierz W (pierwsze 3x3 elementy, zaokrąglone):")
print(np.round(W[:3, :3], 3))

print("\nZsyntetyzowany sygnał x[n] (w dziedzinie czasu):")
# Wyświetlamy z zaokrągleniem
with np.printoptions(precision=3, suppress=True):
    print(x_final)


plt.figure(figsize=(12, 10))

# Wykres 1: Część rzeczywista
plt.subplot(3, 1, 1)
plt.stem(np.arange(N), x_final.real)
plt.title(f'Wariant 1: Zsyntetyzowany sygnał (Część Rzeczywista Re{{x}})')
plt.ylabel('Amplituda')
plt.grid(True, alpha=0.5)

# Wykres 2: Część urojona
plt.subplot(3, 1, 2)
plt.stem(np.arange(N), x_final.imag, linefmt='r-', markerfmt='ro')
plt.title('Zsyntetyzowany sygnał (Część Urojona Im{x})')
plt.ylabel('Amplituda')
plt.grid(True, alpha=0.5)

# Wykres 3: Moduł (Magnituda)
plt.subplot(3, 1, 3)
plt.stem(np.arange(N), np.abs(x_final), linefmt='g-', markerfmt='go')
plt.title('Moduł sygnału |x|')
plt.xlabel('Indeks próbki n')
plt.ylabel('Magnituda')
plt.grid(True, alpha=0.5)

plt.tight_layout()
plt.show()
